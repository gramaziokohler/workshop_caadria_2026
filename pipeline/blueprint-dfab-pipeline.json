{
  "version": "1.11",
  "id": "robotic-fabrication-pipeline",
  "name": "Design-to-Fabrication",
  "description": "Linear design → fabrication → robot pipeline across three GH documents.",
  "tasks": [
    {
      "id": "start",
      "type": "system.start",
      "outputs": [
        {
          "name": "start_time"
        }
      ]
    },
    {
      "id": "design",
      "type": "design.submit",
      "description": "Designer builds and approves a TimberModel in design.gh",
      "outputs": [
        {
          "name": "timber_model",
          "set_to": "timber_model"
        }
      ],
      "depends_on": [
        {
          "id": "start"
        }
      ]
    },
    {
      "id": "fabrication",
      "type": "fabrication.manager",
      "description": "Fabrication manager, chooses the beam to be processed next and marks finished beams as 'fabricated'",
      "scope_start": {
        "name": "fabrication-loop",
        "while_policy": {
          "condition": "has_beams == True"
        }
      },
      "inputs": [
        {
          "name": "timber_model",
          "get_from": "timber_model"
        }
      ],
      "outputs": [
        {
          "name": "timber_model"
        }
      ],
      "depends_on": [
        {
          "id": "design"
        }
      ]
    },
    {
      "id": "robot_simulation",
      "type": "robot.simulate",
      "description": "Machining operator, configures toolpath parameters in the currently fabricated beam, generates toolpaths and triggers fabrication.",
      "scope_start": {
        "name": "simulation-milling-loop",
        "while_policy": {
          "condition": "has_processing == True"
        }
      },
      "inputs": [
        {
          "name": "timber_model"
        }
      ],
      "outputs": [
        {
          "name": "toolpaths"
        },
        {
          "name": "has_processing"
        }
      ],
      "depends_on": [
        {
          "id": "fabrication"
        }
      ]
    },
    {
      "id": "robot_milling",
      "type": "cnc.mill",
      "description": "Executes robotic milling based on the received toolpaths.",
      "scope_end": "robot_simulation",
      "inputs": [
        {
          "name": "toolpaths"
        },
        {
          "name": "has_processing"
        }
      ],
      "depends_on": [
        {
          "id": "robot_simulation"
        }
      ]
    },
    {
      "id": "fabrication_control",
      "type": "fabrication.manager",
      "description": "Broadcast completion to all participants",
      "scope_end": "fabrication",
      "inputs": [
        {
          "name": "timber_model"
        }
      ],
      "outputs": [
        {
          "name": "timber_model"
        }
      ],
      "depends_on": [
        {
          "id": "robot_milling"
        }
      ]
    },
    {
      "id": "confirm_finished",
      "type": "user_prompt.confirm",
      "depends_on": [
        {
          "id": "fabrication_control"
        }
      ]
    },
    {
      "id": "end",
      "type": "system.end",
      "outputs": [
        {
          "name": "end_time"
        }
      ],
      "depends_on": [
        {
          "id": "confirm_finished"
        }
      ]
    }
  ]
}